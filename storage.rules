rules_version = '2';

// Optimized storage rules for MecaniScan v1.5
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Comprehensive image validation: max 10MB and valid MIME type
    function isValidImage() {
      return request.resource != null 
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.startsWith('image/');
    }

    // Rules for Workshop assets
    match /workshops/{userId}/{imageId} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidImage();
      allow delete: if isOwner(userId);
    }

    // Rules for Vehicle assets
    match /vehicles/{userId}/{imageId} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidImage();
      allow delete: if isOwner(userId);
    }
    
    // Global read access, restrictive write
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
