
rules_version = '2';

// Sincronización de reglas para MecaniScan
service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() {
      return request.auth != null;
    }

    // Comprobación de propiedad basada en el UID del usuario
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Validación de subida: tamaño menor a 5MB y tipo de contenido imagen
    function isValidImageUpload() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Las imágenes de talleres son públicas para lectura, pero solo el dueño puede gestionarlas
    match /workshops/{userId}/{imageId} {
      allow read: if true;
      allow write: if isOwner(userId) && (request.method == 'delete' || isValidImageUpload());
    }

    // Las imágenes de vehículos son públicas para lectura, pero solo el dueño puede gestionarlas
    match /vehicles/{userId}/{imageId} {
       allow read: if true;
       allow write: if isOwner(userId) && (request.method == 'delete' || isValidImageUpload());
    }
  }
}
