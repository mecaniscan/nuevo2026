rules_version = '2';

// Reglas de seguridad optimizadas para MecaniScan v1.6
// Permite la gestión de imágenes de talleres y vehículos con validación de tipo y tamaño.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validación de imagen: tamaño máximo 10MB y tipo MIME válido.
    function isValidImage() {
      return request.resource != null 
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.startsWith('image/');
    }

    // Reglas para imágenes de Talleres
    match /workshops/{userId}/{imageId} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidImage();
      allow delete: if isOwner(userId);
    }

    // Reglas para imágenes de Vehículos
    match /vehicles/{userId}/{imageId} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidImage();
      allow delete: if isOwner(userId);
    }
    
    // Acceso de lectura global por defecto, escritura denegada.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
