rules_version = '2';

// Reglas de seguridad para MecaniScan v1.8
// Permite la gestión de imágenes de talleres y vehículos validando la propiedad del usuario.
service firebase.storage {
  match /b/{bucket}/o {

    // Helper para verificar si el usuario es el propietario de la ruta
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Rutas para imágenes de Talleres: Lectura pública, escritura privada para el propietario.
    match /workshops/{userId}/{imageId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Rutas para imágenes de Vehículos: Lectura pública, escritura privada para el propietario.
    match /vehicles/{userId}/{imageId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
    
    // Bloqueo por defecto para cualquier otra ruta de escritura no especificada.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}