rules_version = '2';

// Reglas de seguridad simplificadas para garantizar acceso por UID.
service firebase.storage {
  match /b/{bucket}/o {

    // Regla para imágenes de talleres
    match /workshops/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Regla para imágenes de vehículos
    match /vehicles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Lectura pública por defecto, escritura bloqueada para otras rutas.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}