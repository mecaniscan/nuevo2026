rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() {
      return request.auth != null;
    }

    // Common check for ownership
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Specific check for image uploads (size and content type)
    function isValidImageUpload() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Workshop images can be read by anyone, but only managed by the owner.
    match /workshops/{userId}/{imageId} {
      allow read: if true;
      allow write: if isOwner(userId) && (request.method == 'delete' || isValidImageUpload());
    }

    // Vehicle images can be read by anyone, but only managed by the owner.
    match /vehicles/{userId}/{imageId} {
       allow read: if true;
       allow write: if isOwner(userId) && (request.method == 'delete' || isValidImageUpload());
    }
  }
}
