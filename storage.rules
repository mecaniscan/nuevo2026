rules_version = '2';

// Reglas de seguridad para Firebase Storage.
service firebase.storage {
  match /b/{bucket}/o {

    // Regla para imágenes de talleres: Solo el dueño autenticado puede gestionar su propia carpeta.
    match /workshops/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Regla para imágenes de vehículos: Solo el dueño autenticado puede gestionar su propia carpeta.
    match /vehicles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Lectura pública por defecto para otros recursos, escritura prohibida por defecto.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}