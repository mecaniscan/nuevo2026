rules_version = '2';

// Reglas de seguridad optimizadas para MecaniScan
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validación de imagen: máx 10MB y tipo MIME correcto
    function isValidImage() {
      return request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.startsWith('image/');
    }

    match /workshops/{userId}/{imageId} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidImage();
      allow delete: if isOwner(userId);
    }

    match /vehicles/{userId}/{imageId} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidImage();
      allow delete: if isOwner(userId);
    }
    
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
