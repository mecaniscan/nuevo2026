rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for readability
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isWorkshopOwner(workshopId) {
      return isSignedIn() && get(/databases/$(database)/documents/workshops/$(workshopId)).data.ownerId == request.auth.uid;
    }
    
    // USERS collection
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read, update, delete: if isOwner(userId);
      
      match /oilChanges/{oilChangeId} {
        allow read, list, create, update, delete: if isOwner(userId);
      }

      match /favorites/{workshopId} {
          allow read, list, create, delete: if isOwner(userId);
      }
      
      match /vehicles/{vehicleId} {
        allow read, list, create, update, delete: if isOwner(userId);
      }
    }

    // WORKSHOPS collection
    match /workshops/{workshopId} {
      // Anyone can read workshop data.
      allow get, list: if true;
      // Only an authenticated user can create a workshop for themselves.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      // Allow owner to update everything. 
      // Allow authenticated users to update ONLY review stats (needed for transactions when reviewing).
      allow update: if isOwner(resource.data.ownerId) || 
                    (isSignedIn() && 
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reviewCount', 'averageRating']));
      
      allow delete: if isOwner(resource.data.ownerId);

       // Subcollections of WORKSHOP
      match /services/{serviceId} {
        allow list, get: if true;
        allow create, update, delete: if isWorkshopOwner(workshopId);
      }
      
      match /reviews/{userId} {
        allow list, get: if true;
        // A user can only manage their own review document.
        allow create, update, delete: if isOwner(userId);
      }
    }
    
    // APPOINTMENTS collection
    match /appointments/{appointmentId} {
        allow create: if isOwner(request.resource.data.userId);
        allow read, update, delete: if isOwner(resource.data.userId) || isWorkshopOwner(resource.data.workshopId);
    }

    // MARKETPLACE collection
    match /marketplace/{vehicleId} {
      allow get, list: if true;
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }
  }
}