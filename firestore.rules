/**
 * This ruleset defines the security model for the MechConnect application.
 *
 * Core Philosophy:
 * The security model enforces a strict user-ownership paradigm for all user-generated
 * content, ensuring that users can only access and manage their own data.
 * Publicly available data, such as workshop and service listings, is readable
 * by anyone but is not modifiable by clients. This creates a clear separation
 * between private user spaces and the public data commons.
 *
 * Data Structure:
 * The data is organized into several top-level collections: 'users' and 'workshops'.
 * All data private to a user, such as 'appointments', is stored in
 * a subcollection directly under that user's document in the '/users/{userId}' path.
 * Data specific to a workshop, like 'reviews' and 'services', is stored in subcollections
 * under the workshop's document.
 *
 * Key Security Decisions:
 * - User Data Privacy: A user can only read, write, and query data within their
 *   own document tree (e.g., /users/their-own-id/...).
 * - User Enumeration Disabled: Listing documents in the top-level 'users'
 *   collection is explicitly forbidden to protect user privacy.
 * - Public Data is Read-Only (mostly): The 'workshops' collection is
 *   publicly readable. Workshop owners can create, update, and delete their own workshop.
 * - Default Deny: Any operation not explicitly granted is denied.
 *
 * Denormalization for Authorization:
 * To ensure fast and secure authorization checks, key identifying information is
 * denormalized. For instance, an 'Appointment' document created at
 * '/users/{userId}/appointments/{appointmentId}' must contain a 'userId' field
 * that matches the '{userId}' from the path.
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's ID matches the provided userId.
     * This is the core of the ownership model.
     * @param userId The user ID to check against the authenticated user.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Validates that the document being operated on already exists in Firestore.
     * Essential for secure update and delete operations.
     */
    function isExistingDocument() {
      return resource != null;
    }

    /**
     * Combines ownership check with an existence check.
     * Ensures an owner can't modify a document that doesn't exist.
     * @param userId The user ID to check against the authenticated user.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDocument();
    }
    
    /**
     * Checks if the incoming workshop data is valid for a create operation.
     * The new workshop must be owned by the person creating it.
     */
    function isValidNewWorkshop() {
      return request.resource.data.ownerId == request.auth.uid;
    }
    
    /**
     * Checks if the incoming workshop data is valid for an update.
     * The ownerId cannot be changed.
     */
    function isValidWorkshopUpdate() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }


    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    /**
     * @description Controls access to the public directory of workshops.
     * @path /workshops/{workshopId}
     * @allow (get, list) Any user, signed in or not, can read workshop data.
     * @deny (create, update, delete) Any client trying to modify workshop data.
     * @principle Public data should be read-only for clients to prevent vandalism.
     */
    match /workshops/{workshopId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isValidNewWorkshop();
      allow update: if isExistingOwner(resource.data.ownerId) && isValidWorkshopUpdate();
      allow delete: if isExistingOwner(resource.data.ownerId);

      /**
       * @description Secures workshop reviews.
       * @path /workshops/{workshopId}/reviews/{reviewId}
       * @allow (list, get) Any user can read reviews.
       * @allow (create) Authenticated users can create reviews.
       * @allow (update, delete) Only the review's owner can modify or delete it.
       */
      match /reviews/{reviewId} {
        allow list: if true;
        allow get: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isExistingOwner(resource.data.userId);
      }
      
      /**
       * @description Secures workshop services.
       * @path /workshops/{workshopId}/services/{serviceId}
       * @allow (list, get) Any user can read services for a workshop.
       * @allow (create, update, delete) Only the workshop owner can manage their services.
       */
       match /services/{serviceId} {
         allow list, get: if true;
         allow create, update, delete: if isOwner(get(/databases/$(database)/documents/workshops/$(workshopId)).data.ownerId);
       }
    }

    /**
     * @description Secures user profile documents.
     * @path /users/{userId}
     * @allow (get, update, delete) A user can manage their own profile.
     * @allow (create) A new user can create their own profile document.
     * @deny (get) Another user trying to read someone else's profile.
     * @deny (list) Any client trying to get a list of all application users.
     * @principle Restricts access to a user's own data tree and prevents user enumeration.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Secures a user's appointments subcollection.
       * @path /users/{userId}/appointments/{appointmentId}
       * @allow (get, list, create, update, delete) A user can manage their own appointments.
       * @deny (get) A user trying to access another user's appointment.
       * @principle Enforces strict data ownership for sensitive subcollections.
       */
      match /appointments/{appointmentId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
      
      /**
       * @description Secures a user's oil changes subcollection.
       * @path /users/{userId}/oilChanges/{oilChangeId}
       * @allow (get, list, create, update, delete) A user can manage their own oil change records.
       */
      match /oilChanges/{oilChangeId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }
  }
}
    