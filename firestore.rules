rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Funciones auxiliares para legibilidad y seguridad
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isWorkshopOwner(workshopId) {
      return isSignedIn() && get(/databases/$(database)/documents/workshops/$(workshopId)).data.ownerId == request.auth.uid;
    }
    
    // Colección de USUARIOS
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read, update, delete: if isOwner(userId);
      
      match /oilChanges/{oilChangeId} {
        allow read, list, create, update, delete: if isOwner(userId);
      }

      match /favorites/{favWorkshopId} {
          allow read, list, create, delete: if isOwner(userId);
      }
      
      match /vehicles/{vehicleId} {
        allow read, list, create, update, delete: if isOwner(userId);
      }
    }

    // Colección de TALLERES
    match /workshops/{workshopId} {
      // Lectura pública permitida para todos.
      allow get, list: if true;
      
      // Creación: Solo usuarios registrados y estableciendo su propio ownerId.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      // Actualización: 
      // 1. El dueño puede editar todo.
      // 2. Otros usuarios (clientes) pueden actualizar SOLO las estadísticas de reseñas mediante transacciones.
      allow update: if isSignedIn() && (
        isOwner(resource.data.ownerId) || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reviewCount', 'averageRating']) && 
         request.resource.data.ownerId == resource.data.ownerId)
      );
      
      allow delete: if isOwner(resource.data.ownerId);

       // Subcolecciones de TALLER
      match /services/{serviceId} {
        allow list, get: if true;
        allow create, update, delete: if isWorkshopOwner(workshopId);
      }
      
      match /reviews/{reviewUserId} {
        allow list, get: if true;
        // Un usuario solo puede gestionar su propio documento de reseña por su UID.
        allow create, update, delete: if isSignedIn() && request.auth.uid == reviewUserId;
      }
    }
    
    // Colección de CITAS
    match /appointments/{appointmentId} {
        allow create: if isOwner(request.resource.data.userId);
        allow read, update, delete: if isOwner(resource.data.userId) || isWorkshopOwner(resource.data.workshopId);
    }

    // Colección de MARKETPLACE
    match /marketplace/{marketVehicleId} {
      allow get, list: if true;
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }
  }
}