
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the requesting user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * On workshop create, validates the owner is the signed-in user.
     */
    function isWorkshopCreator() {
      return isOwner(request.resource.data.ownerId);
    }
    
    /**
     * On workshop update, ensures the owner field cannot be changed.
     */
    function workshopOwnerIsUnchanged() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }

    /**
     * Checks if the user is either the one who booked the appointment
     * or the owner of the workshop associated with the appointment.
     * This requires one 'get' call, which is a standard and secure pattern.
     */
    function isAppointmentParticipant(appointment) {
      let isUser = isOwner(appointment.userId);
      let isWorkshopOwner = isOwner(get(/databases/$(database)/documents/workshops/$(appointment.workshopId)).data.ownerId);
      return isUser || isWorkshopOwner;
    }

    //-------------------------------------------------------------------------
    // Collection Rules
    //-------------------------------------------------------------------------

    /**
     * @description Rules for a user's own profile document and subcollections.
     * @path /users/{userId}
     * @principle Restricts access to a user's own data tree, a core privacy principle.
     */
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }
    
    /**
     * @description Rules for workshop documents. Workshops are public to read but can only be written by their owner.
     * @path /workshops/{workshopId}
     * @principle Enforces document ownership for writes while allowing public read access for discovery.
     */
    match /workshops/{workshopId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isWorkshopCreator();
      allow update: if isSignedIn() && isOwner(resource.data.ownerId) && workshopOwnerIsUnchanged();
      allow delete: if isSignedIn() && isOwner(resource.data.ownerId);
      
      // Workshop subcollections (e.g., services, reviews)
      match /services/{serviceId} {
        allow read: if true;
        // Writes are handled by the workshop owner, inherited from the parent `update` rule logic
        allow write: if isSignedIn() && isOwner(get(/databases/$(database)/documents/workshops/$(workshopId)).data.ownerId);
      }
      
      match /reviews/{reviewId} {
        allow read, list: if true;
        // Allow any signed-in user to create a review, but not to update or delete.
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    /**
     * @description Rules for appointment documents. Access is shared between the user who booked and the workshop owner.
     * @path /appointments/{appointmentId}
     * @principle Secures a document based on relationships to other documents (user and workshop).
     */
    match /appointments/{appointmentId} {
      allow get: if isSignedIn() && isAppointmentParticipant(resource.data);
      allow list: if false; // Prevent listing all appointments. Queries must be used.
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isAppointmentParticipant(resource.data);
      allow delete: if isSignedIn() && isAppointmentParticipant(resource.data);
    }

    /**
     * @description Rules for the OBD codes collection, which is public, read-only reference data.
     * @path /obd_codes/{obdCodeId}
     * @principle Establishes a globally readable but client-immutable data collection.
     */
    match /obd_codes/{obdCodeId} {
      allow get, list: if true;
      allow write: if false;
    }

    /**
     * @description Publicly readable vehicle marketplace. This collection is read-only for clients.
     *              Data is populated by a backend process (simulated by user-side batch write).
     * @path /marketplace/{vehicleId}
     * @principle Public read-only data, write access is disabled for clients.
     */
    match /marketplace/{vehicleId} {
        allow get, list: if true;
        // Client-side writes are disallowed. Writes happen through a batch from a trusted context (the user's own vehicle management page).
        allow write: if false; 
    }
  }
}
